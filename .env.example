# ============================================
# Root-level Environment Variables Example
# Copy this file to .env and fill in actual values
# This file is for root-level services (primarily for docker-compose.yml)
# Detailed backend configuration is in backend/.env.example
# ============================================

# Application Environment
APP_ENV=development
DEBUG=true

# Server Ports
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Database Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5433
POSTGRES_USER=blog_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=blog_db

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6380
REDIS_PASSWORD=

# Flower Monitoring (Production)
FLOWER_USER=admin
FLOWER_PASSWORD=your_flower_password_here

# ============================================
# For complete backend configuration including:
# - JWT settings
# - AI service configuration
# - Celery configuration
# - Rate limiting
# - Logging
# - Email settings
# - Security settings
# 
# Please see: backend/.env.example
# ============================================
