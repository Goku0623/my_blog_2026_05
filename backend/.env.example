# ============================================
# Application Environment Configuration
# ============================================

# Application Mode: development, production, testing
APP_ENV=development

# Debug Mode (disable in production)
DEBUG=true

# Secret Key for JWT Token Generation (use a strong random string in production)
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars

# JWT Configuration (must match app/core/config.py field names)
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7


# ============================================
# Server Configuration
# ============================================

# Backend API Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Allowed CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# ============================================
# Database Configuration
# ============================================

# PostgreSQL Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=blog_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=blog_db

# Database Connection URL (auto-generated from above, or override)
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Database Pool Configuration
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20


# ============================================
# Redis Configuration
# ============================================

# Redis Server
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis Connection URL
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# Redis Cache TTL (seconds)
CACHE_TTL=300


# ============================================
# Celery Configuration
# ============================================

# Celery Broker & Result Backend
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Celery Worker Configuration
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=Asia/Shanghai
CELERY_ENABLE_UTC=false

# Celery Task Time Limits (seconds)
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600


# ============================================
# Flower Monitoring (Production)
# ============================================

FLOWER_USER=admin
FLOWER_PASSWORD=your_flower_password_here
FLOWER_PORT=5555


# ============================================
# AI Service Configuration
# ============================================

# N8N Workflow Integration
N8N_WEBHOOK_URL=http://your-n8n-instance.com/webhook/your-webhook-id
N8N_SECRET=your_n8n_secret_key_here

# OpenAI Compatible API
AI_API_KEY=your_openai_api_key_here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-3.5-turbo
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1000

# AI Rate Limiting
AI_REQUESTS_PER_MINUTE=10
AI_REQUESTS_PER_DAY=100


# ============================================
# Weather Service Configuration
# ============================================

# Supported Providers: amap (高德), baidu (百度), openweather
WEATHER_PROVIDER=amap
WEATHER_API_KEY=your_weather_api_key_here

# Weather Cache TTL (seconds)
WEATHER_CACHE_TTL=1800


# ============================================
# File Upload Configuration
# ============================================

# Upload Directory
UPLOAD_DIR=./uploads

# Max File Size (bytes, default 10MB)
MAX_UPLOAD_SIZE=10485760

# Allowed File Extensions (comma-separated)
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,pdf,doc,docx


# ============================================
# Rate Limiting Configuration
# ============================================

# Global Rate Limits
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# API Specific Rate Limits
API_RATE_LIMIT_LOGIN=5/minute
API_RATE_LIMIT_REGISTER=3/hour
API_RATE_LIMIT_AI_CHAT=10/minute


# ============================================
# Logging Configuration
# ============================================

# Log Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log File Path
LOG_FILE=./logs/app.log

# Log Rotation
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5


# ============================================
# Email Configuration (Optional)
# ============================================

# SMTP Server
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password_here
SMTP_TLS=true

# Email Sender
EMAIL_FROM=noreply@yourblog.com
EMAIL_FROM_NAME=Your Blog


# ============================================
# Backup Configuration
# ============================================

# Database Backup Directory
BACKUP_DIR=./backups

# Backup Retention Days
BACKUP_RETENTION_DAYS=30


# ============================================
# Security Configuration
# ============================================

# Password Hashing (bcrypt rounds, recommended: 12-14)
BCRYPT_ROUNDS=12

# Session Configuration
SESSION_SECRET=your-session-secret-change-this-in-production
SESSION_EXPIRE_MINUTES=60

# CSRF Protection
CSRF_ENABLED=true


# ============================================
# Feature Flags
# ============================================

# Enable/Disable Features
FEATURE_AI_CHAT=true
FEATURE_WEATHER=true
FEATURE_EMAIL_VERIFICATION=false
FEATURE_SOCIAL_LOGIN=false


# ============================================
# Monitoring & Analytics
# ============================================

# Sentry Error Tracking (Optional)
SENTRY_DSN=

# Google Analytics ID (Optional)
GA_TRACKING_ID=


# ============================================
# Development Tools
# ============================================

# Auto-reload on code changes (development only)
DEV_RELOAD=true

# SQL Query Logging (development only)
LOG_SQL_QUERIES=false
